<!-- Floating Dictionary Popup -->
<div id="dictionaryPopup" class="floating-popup">
  <div id="popupHeader" class="popup-header">
    <strong>Dictionary</strong>
    <span id="popupClose" class="popup-close" title="Close">&times;</span>
  </div>
  <input type="text" id="dictInput" placeholder="Type a word..." name="word">
  <button id="dictSearch" class="btn primary">Search</button>
  <div id="dictMeaning" class="dict-meaning" style="display:none;"></div>
</div>

<!-- Minimized icon -->
<div id="dictionaryIcon" class="dictionary-icon" title="Open Dictionary" style="display:none;">
  📖
</div>


<!-- Write Blog Popup -->
<div id="blogModal" class="blog-modal">
  <div class="blog-modal-content">
    <button id="closeBlogModal" class="close-btn">×</button>

    <h2 class="modal-title">📝 Submit Your Blog Post</h2>
    <p class="modal-subtext">
      Share your knowledge with our tech community. Fill out the form below to submit your blog post.
    </p>

    <form id="blogForm">
      <label>Blog Title *</label>
      <input type="text" id="blogTitle" class="input" placeholder="Enter an engaging title for your blog post" name="blogTitle" required />

      <label>Excerpt *</label>
      <textarea id="blogExcerpt" class="input" placeholder="Write a brief summary of your blog post (2–3 sentences)"  name="excerpt" required></textarea>

      <label>Category *</label>
      <select id="blogCategory" class="input" required>
        <option value="">Select a category</option>
        <option>3D Animation</option>
        <option>Software Development</option>
        <option>Technology</option>
        <option>Computer Hardware</option>
      </select>

      <label>Blog Content *</label>
      <textarea id="blogContent" class="input textarea" placeholder="Write your full blog post content here..." name ="blogPost" required></textarea>
      <small id="charCount">0 characters (minimum 100)</small>

      <div class="row">
        <div class="col">
          <label>Author Name *</label>
          <input type="text" id="blogAuthor" class="input" placeholder="Your name"  name ="yourName" required />
        </div>
        <div class="col">
          <label>Email *</label>
          <input type="email" id="blogEmail" class="input" placeholder="your.email@example.com" name ="email" required />
        </div>
      </div>

      <div class="row">
        <div class="col">
          <label>Featured Image URL </label>
          <input type="text" id="blogImage" class="input" placeholder="https://example.com/image.jpg" />
        </div>
        <div class="col">
          <label>Estimated Read Time *</label>
          <input type="text" id="blogReadTime" class="input" placeholder="e.g., 5 min read"  name ="readTime" required />
        </div>
      </div>

      <div class="btn-row">
        <button type="button" id="cancelBlog" class="cancel-btn">Cancel</button>
        <button type="submit" class="submit-btn">Submit Blog Post</button>
      </div>
    </form>
  </div>
</div>



